# ============================================================
# HCI Experiment — Environment Variables
# Copy to .env.local and fill in real values
# Run: vercel env pull .env.local  (after linking Blob store)
# ============================================================

# --- Vercel Blob ---
# Set automatically when Blob store is linked to this project.
# Locally: run `vercel env pull .env.local` to populate.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXX

# --- Supabase ---
# Required for server-side DB access in Next.js route handlers and scripts.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Preferred backend credential for server-only DB access.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxx

# Legacy fallback only. Use this only if your project does not expose a secret key yet.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional dedicated password for /stats and /api/paper-stats.
# Falls back to STATS_SECRET when omitted.
# PAPER_STATS_SECRET=choose-a-separate-password

# Optional. Not used by this app today because Supabase is server-only here.
# Add only if you later introduce browser-side Supabase/Auth usage.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx

# --- Prolific Integration ---
# Get the completion code from Prolific → Study → "Record completions manually"
# Format: https://app.prolific.co/submissions/complete?cc=YOUR_CODE
NEXT_PUBLIC_PROLIFIC_COMPLETION_URL=https://app.prolific.co/submissions/complete?cc=PLACEHOLDER

# --- Optional: condition override for local testing ---
# Pass ?condition=G1 (or G2/G3/G4) in the URL query string to bypass assignment.
# No env var needed — handled by the assign route directly.
