# ============================================================
# HCI Experiment — Environment Variables
# Copy to .env.local and fill in real values
# Run: vercel env pull .env.local  (after linking Blob store)
# ============================================================

# --- Vercel Blob ---
# Set automatically when Blob store is linked to this project.
# Locally: run `vercel env pull .env.local` to populate.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXX

# --- Prolific Integration ---
# Get the completion code from Prolific → Study → "Record completions manually"
# Format: https://app.prolific.co/submissions/complete?cc=YOUR_CODE
NEXT_PUBLIC_PROLIFIC_COMPLETION_URL=https://app.prolific.co/submissions/complete?cc=PLACEHOLDER

# --- Optional: condition override for local testing ---
# Pass ?condition=G1 (or G2/G3/G4) in the URL query string to bypass assignment.
# No env var needed — handled by the assign route directly.
