{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "contract": {
      "description": "Contract agent — owns docs/contracts/*, validates all config changes",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./agent/contract.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "git push*": "deny",
          "git commit*": "deny",
          "npm run*": "deny",
          "npx*": "deny"
        }
      }
    },
    "ui": {
      "description": "UI Prototype agent — renders all 4 condition screens",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./agent/ui.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "npm run dev": "allow",
          "npm run build": "allow"
        }
      }
    },
    "instrumentation": {
      "description": "Instrumentation/Data agent — logger, timing, API routes, DB schema",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./agent/instrumentation.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "npm run dev": "allow",
          "npm run build": "allow",
          "npx tsc*": "allow"
        }
      }
    },
    "qa": {
      "description": "QA agent — E2E Playwright tests for G1–G4 flows",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./agent/qa.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "npx playwright test*": "allow",
          "npm run test*": "allow"
        }
      }
    },
    "devops": {
      "description": "DevOps agent — Vercel deployment, env vars, DB migrations",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./agent/devops.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "vercel deploy*": "allow",
          "vercel env*": "allow",
          "npx vercel*": "allow"
        }
      }
    }
  }
}
